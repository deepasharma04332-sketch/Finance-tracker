# Copy this file to .env and fill in your real values.
# Default (no DATABASE_URL set) uses SQLite — zero setup, good for local dev/testing.

# To use MySQL instead, uncomment and edit:
# DATABASE_URL=mysql+pymysql://root:yourpassword@localhost:3306/finance_tracker

JWT_SECRET_KEY=change-this-to-a-long-random-string
CORS_ORIGINS=http://localhost:5173
